<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console Appender with colored output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %highlight(%-5level) %cyan(%logger{15}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender with rolling policy -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>astrox.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>astrox.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Audit Logger — writes ONLY to audit file -->
    <appender name="AUDIT" class="ch.qos.logback.core.FileAppender">
        <file>${user.home}/.astrox/audit.log</file>
        <append>true</append>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <logger name="dev.naruto.astrox.audit" level="INFO" additivity="false">
        <appender-ref ref="AUDIT"/>
    </logger>

    <!-- AstroX loggers -->
    <logger name="dev.naruto.astrox" level="DEBUG"/>
    <logger name="dev.naruto.astrox.obfuscation" level="DEBUG"/>
    <logger name="dev.naruto.astrox.core" level="INFO"/>

    <!-- Suppress noisy third-party loggers -->
    <logger name="org.objectweb.asm" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
